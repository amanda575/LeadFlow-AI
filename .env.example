# ==========================================================================
# LeadFlow AI - Environment Configuration
# Copy this file to ".env" and fill in your real values.
# NEVER commit the real .env to version control.
# ==========================================================================

# --- Flask / Dashboard ---------------------------------------------------
SECRET_KEY=change-me-to-a-long-random-string
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false

# Dashboard authentication (password is hashed at first run if PLAINTEXT given)
DASHBOARD_USERNAME=admin
# Provide EITHER a plaintext password (auto-hashed on boot) ...
DASHBOARD_PASSWORD=changeme
# ... OR a precomputed werkzeug hash (takes precedence if set)
DASHBOARD_PASSWORD_HASH=
SESSION_TIMEOUT_MINUTES=60

# --- SMTP (SENDING ONLY) -------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=amanda@seoleads.me
SMTP_PASSWORD=your-app-password-here
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_FROM_NAME=Amanda @ SeoLeads
SMTP_FROM_EMAIL=amanda@seoleads.me
SMTP_MAX_RETRIES=3
SMTP_RETRY_DELAY_SECONDS=30

# --- Gmail API (READING ONLY) --------------------------------------------
# OAuth client secret downloaded from Google Cloud Console.
GMAIL_CREDENTIALS_FILE=credentials/credentials.json
GMAIL_TOKEN_FILE=credentials/token.json
# The Gmail label that marks a thread as a lead to follow up.
GMAIL_LABEL=Follow Up
# Remove the label automatically once a reply is detected / lead completes.
GMAIL_AUTO_REMOVE_LABEL=false

# --- Business Hours ------------------------------------------------------
BUSINESS_START_HOUR=9
BUSINESS_END_HOUR=17
BUSINESS_TIMEZONE=America/New_York
BUSINESS_WEEKDAYS_ONLY=true

# --- Scheduler intervals (minutes) ---------------------------------------
IMPORT_INTERVAL_MINUTES=5
REPLY_INTERVAL_MINUTES=2
SEND_INTERVAL_MINUTES=5
RETRY_INTERVAL_MINUTES=15
HEALTH_INTERVAL_MINUTES=10

# --- Notifications -------------------------------------------------------
NOTIFY_DESKTOP=true
NOTIFY_SOUND=true
NOTIFY_CONSOLE=true

# --- Backups / Logs ------------------------------------------------------
BACKUP_RETENTION=30
LOG_RETENTION_DAYS=30

# --- AI (optional, future) -----------------------------------------------
# Leave provider empty to disable AI features entirely.
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=
